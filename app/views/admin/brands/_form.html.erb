<%= form_with model: [:admin, brand], class: "admin-form" do |f| %>
  <% if brand.errors.any? %>
    <div class="error-list">
      <strong><%= pluralize(brand.errors.count, "error") %> impidieron guardar esta marca:</strong>
      <ul>
        <% brand.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :name, "Nombre" %>
    <%= f.text_field :name %>
  </div>

  <div class="field">
    <%= f.label :description, "Descripción" %>
    <%= f.text_area :description %>
  </div>

  <div class="field">
    <%= f.label :country_of_origin, "País de origen" %>
    <%= f.text_field :country_of_origin %>
  </div>

  <div class="form-actions">
    <%= f.submit brand.new_record? ? "Crear marca" : "Guardar cambios", class: "btn-primary" %>
  </div>
<% end %>
