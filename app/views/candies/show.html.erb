<% content_for(:title, "#{@candy.name} — Candy Directory") %>

<h1><%= @candy.name %></h1>

<p class="candy-meta">
  Marca: <%= link_to @candy.brand.name, @candy.brand %> &middot;
  Categoría: <%= link_to @candy.category.name, @candy.category %>
</p>

<% if @candy.description.present? %>
  <p><%= @candy.description %></p>
<% end %>

<% if @candy.year_introduced %>
  <p>Introducido en: <%= @candy.year_introduced %></p>
<% end %>

<p><%= @candy.discontinued? ? "Descontinuado" : "Disponible" %></p>

<%= link_to "← Volver a dulces", candies_path %>
