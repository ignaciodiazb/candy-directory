<% content_for(:title, "Categorías — Candy Directory") %>

<h1>Categorías</h1>

<% @categories.each do |category| %>
  <div class="category-card">
    <h2><%= link_to category.name, category %></h2>
    <% if category.description.present? %>
      <p><%= category.description %></p>
    <% end %>
  </div>
<% end %>
